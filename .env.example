# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE CONFIGURATION
# Optional. Leave empty to use the robust local persistent JSON-database fallback in AI Studio.
MONGO_URI=""
MONGODB_URI=""

# FRONTEND-BACKEND INTEGRATION CONFIGURATION
# Configure the frontend application to point to the production Railway backend API
VITE_API_URL=https://roymenfashion-production.up.railway.app

# CLOUDINARY CONFIGURATION
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SECURITY CONFIGURATION
# Custom secret string to sign and verify JSON Web Tokens (JWT)
JWT_SECRET=""

# PAYMENT GATEWAY PERSONAL WALLETS
BKASH_PERSONAL_NUMBER=+8801721922927
NAGAD_PERSONAL_NUMBER=+8801721922927

# BREVO TRANSACTIONAL REST API CONFIGURATION
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="ROY MEN <your-verified-sender@domain.com>"
EMAIL_FROM_NAME="ROY MEN"
ADMIN_EMAIL="admin-email@gmail.com"

# GOOGLE APPS SCRIPT WEBHOOK URL
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/xxxxxxxx/exec"
